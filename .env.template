# ── LLM ───────────────────────────────────────────────────────────────────────
# API key for the LLM provider (Anthropic, OpenAI, Groq, etc.)
LLM_API_KEY=

# Base URL of an OpenAI-compatible completions API
LLM_BASE_URL=https://api.anthropic.com/v1

# Model identifier passed to the API
LLM_MODEL=claude-sonnet-4-6

# Embeddings always use OpenAI — set a separate key if your LLM provider differs
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=  # optional; falls back to LLM_API_KEY if blank

# System prompt template file path
# Defaults to system_prompts/alex.md
# SYSTEM_PROMPT_PATH=system_prompts/alex.md

# ── Discord ────────────────────────────────────────────────────────────────────
DISCORD_TOKEN=

# Comma-separated Discord user IDs that the bot will respond to
DISCORD_ALLOWED_USER_IDS=

# ── Paths ──────────────────────────────────────────────────────────────────────
# Relative to the project root (or absolute)
LANCEDB_PATH=data/lancedb
GOOGLE_TOKEN_PATH=data/google_token.json

# ── Memory / context ───────────────────────────────────────────────────────────
# How many past memories to inject into each prompt
MEMORY_TOP_K=5

# Approximate token budget for the context window
CONTEXT_TOKEN_LIMIT=8000

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Comma-separated UTC hours at which the nightly summarisation job runs
# e.g. "2" → 02:00 UTC   "2,14" → 02:00 and 14:00 UTC
SUMMARISATION_HOURS=2

# ── Confirmation gate ─────────────────────────────────────────────────────────
# Seconds to wait for a yes/no reaction before aborting a write action
CONFIRMATION_TIMEOUT_SECONDS=60

# ── Skills ────────────────────────────────────────────────────────────────────
# Comma-separated skill module names to load (e.g. "calendar,email")
ENABLED_SKILLS=
